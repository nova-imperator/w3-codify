# ============================================================
# W3Codify — Environment Variables (EXAMPLE — no secrets here)
# Copy to .env and fill in real values. .env is gitignored.
# ============================================================

# ---------- App ----------
NODE_ENV=development
PORT=3000

# ---------- Database (PostgreSQL on AWS RDS, ap-south-1) ----------
DB_HOST=<rds-endpoint>
DB_PORT=5432
DB_NAME=w3codify
DB_USER=postgres
DB_PASSWORD=<password>
DB_SSL=true
DATABASE_URL=postgresql://postgres:<password>@<rds-endpoint>:5432/w3codify?sslmode=require

# ---------- Auth.js (NextAuth v5) ----------
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------- OTP / SMS / WhatsApp (MSG91) ----------
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_OTP_TEMPLATE_ID=

# ---------- Bot protection (reCAPTCHA v3) ----------
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ---------- AWS / S3 / CloudFront ----------
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
CLOUDFRONT_URL=

# ---------- Video (Mux) ----------
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# ---------- Payments (Razorpay) ----------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---------- AI (Anthropic Claude) ----------
ANTHROPIC_API_KEY=

# ---------- Email (SES or Resend) ----------
SES_FROM_EMAIL=
RESEND_API_KEY=
